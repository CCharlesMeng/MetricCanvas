DATABASE_URL=postgres://metriccanvas:metriccanvas@localhost:5432/metriccanvas
DATA_SERVICE_URL=http://localhost:18226
PLATFORM_ORIGIN=http://localhost:5174
RUNTIME_ORIGIN=http://localhost:5173

# 设为 1 时使用进程内页面生命周期和仓库元数据快照；通常直接运行 pnpm dev:offline。
METRICCANVAS_OFFLINE=0

# 默认 scripted;手工 DeepSeek 验收时改为 deepseek 并只在本地 .env 填写 Key。
AGENT_MODEL_PROVIDER=scripted
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

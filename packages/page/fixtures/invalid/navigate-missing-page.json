{
  "formatVersion": "1.0",
  "id": "navigate-missing-page",
  "title": "navigate 缺少必填的目标页 id",
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-by-region",
      "type": "barChart",
      "position": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "query": { "metrics": ["gmv"], "dimensions": ["region"] },
      "interactions": [
        {
          "on": "click",
          "navigate": {
            "setFilters": { "f-region": "$dimension.region" }
          }
        }
      ]
    }
  ]
}

{
  "formatVersion": "1.0",
  "id": "demo",
  "title": "演示看板",
  "filters": [
    { "id": "f-region", "type": "dimension", "dimension": "region" }
  ],
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-by-channel",
      "type": "barChart",
      "position": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "query": { "metrics": ["gmv"], "dimensions": ["channel"] },
      "interactions": [
        { "on": "click", "writeFilter": "f-region", "value": "$dimension.channel" }
      ]
    }
  ]
}

{
  "formatVersion": "1.0",
  "id": "navigate-set-dimension-not-queried",
  "title": "setFilters 占位引用了查询之外的维度",
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-by-region",
      "type": "barChart",
      "position": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "query": { "metrics": ["gmv"], "dimensions": ["region"] },
      "interactions": [
        {
          "on": "click",
          "navigate": {
            "page": "sales-detail",
            "setFilters": { "f-channel": "$dimension.channel" }
          }
        }
      ]
    }
  ]
}

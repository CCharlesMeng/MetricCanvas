{
  "formatVersion": "1.0",
  "id": "with-filters",
  "title": "带筛选联动的页面",
  "filters": [
    { "id": "f-time", "type": "timeRange", "label": "时间范围", "default": "last30d" },
    {
      "id": "f-region",
      "type": "dimension",
      "dimension": "region",
      "label": "区域",
      "display": "select",
      "default": ["华东"]
    },
    {
      "id": "f-channel",
      "type": "dimension",
      "dimension": "channel",
      "label": "渠道",
      "display": "tabs"
    }
  ],
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-gmv",
      "type": "metricCard",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "query": { "metrics": ["gmv"], "filters": { "subscribe": ["f-time", "f-region"] } }
    },
    {
      "id": "w-by-region",
      "type": "barChart",
      "position": { "x": 0, "y": 2, "w": 6, "h": 4 },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["region"],
        "filters": { "subscribe": ["f-time", "f-channel"] }
      },
      "interactions": [
        { "on": "click", "writeFilter": "f-region", "value": "$dimension.region" }
      ]
    }
  ]
}

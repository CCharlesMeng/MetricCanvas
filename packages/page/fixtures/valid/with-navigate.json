{
  "formatVersion": "1.0",
  "id": "with-navigate",
  "title": "带跨页下钻交互的页面",
  "filters": [
    { "id": "f-time", "type": "timeRange", "label": "时间范围", "default": "last30d" },
    { "id": "f-region", "type": "dimension", "dimension": "region", "label": "区域" }
  ],
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-by-channel",
      "type": "barChart",
      "position": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["channel"],
        "filters": { "subscribe": ["f-time", "f-region"] }
      },
      "interactions": [
        {
          "on": "click",
          "navigate": {
            "page": "sales-detail",
            "carryFilters": ["f-time", "f-region"],
            "setFilters": { "f-channel": "$dimension.channel" }
          }
        }
      ]
    }
  ]
}

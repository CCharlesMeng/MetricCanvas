{
  "formatVersion": "1.0",
  "id": "demo",
  "title": "演示看板(筛选联动)",
  "description": "筛选联动演示:筛选器、页内下钻、跨页下钻(跳销售明细)、URL 可分享",
  "filters": [
    { "id": "f-time", "type": "timeRange", "label": "时间范围", "default": "last30d" },
    { "id": "f-region", "type": "dimension", "dimension": "region", "label": "区域", "display": "select" },
    { "id": "f-channel", "type": "dimension", "dimension": "channel", "label": "渠道", "display": "tabs" }
  ],
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-gmv",
      "type": "metricCard",
      "title": "本月 GMV",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "query": {
        "metrics": ["gmv"],
        "filters": { "subscribe": ["f-time", "f-region", "f-channel"] }
      },
      "display": { "prefix": "¥", "thousandsSeparator": true }
    },
    {
      "id": "w-order-count",
      "type": "metricCard",
      "title": "订单数(不随区域/渠道筛选)",
      "position": { "x": 3, "y": 0, "w": 3, "h": 2 },
      "query": {
        "metrics": ["order-count"],
        "filters": { "subscribe": ["f-time"] }
      },
      "display": { "unit": "单", "thousandsSeparator": true }
    },
    {
      "id": "w-by-region",
      "type": "barChart",
      "title": "GMV 按区域(点击柱条下钻)",
      "position": { "x": 0, "y": 2, "w": 6, "h": 4 },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["region"],
        "filters": { "subscribe": ["f-time", "f-channel"] }
      },
      "interactions": [
        { "on": "click", "writeFilter": "f-region", "value": "$dimension.region" }
      ]
    },
    {
      "id": "w-by-channel",
      "type": "barChart",
      "title": "GMV 按渠道(点击柱条跳销售明细)",
      "position": { "x": 6, "y": 2, "w": 6, "h": 4 },
      "display": { "rounded": true },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["channel"],
        "filters": { "subscribe": ["f-time", "f-region"] }
      },
      "interactions": [
        {
          "on": "click",
          "navigate": {
            "page": "sales-detail",
            "carryFilters": ["f-time", "f-region"],
            "setFilters": { "f-channel": "$dimension.channel" }
          }
        }
      ]
    },
    {
      "id": "w-trend",
      "type": "lineChart",
      "title": "GMV 趋势(平滑 + 面积渐变)",
      "position": { "x": 0, "y": 6, "w": 8, "h": 4 },
      "display": { "smooth": true, "areaGradient": true },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["mtime"],
        "filters": { "subscribe": ["f-time", "f-region", "f-channel"] }
      }
    },
    {
      "id": "w-channel-share",
      "type": "pieChart",
      "title": "GMV 渠道占比(环形,点击扇区下钻)",
      "position": { "x": 8, "y": 6, "w": 4, "h": 4 },
      "display": { "ring": "55%" },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["channel"],
        "filters": { "subscribe": ["f-time", "f-region"] }
      },
      "interactions": [
        { "on": "click", "writeFilter": "f-channel", "value": "$dimension.channel" }
      ]
    }
  ]
}

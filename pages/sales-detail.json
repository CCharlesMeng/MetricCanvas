{
  "formatVersion": "1.0",
  "id": "sales-detail",
  "title": "销售明细(跨页下钻目标页)",
  "description": "承接演示看板的跨页下钻:从 URL 恢复筛选状态,展示区域/渠道明细",
  "filters": [
    { "id": "f-time", "type": "timeRange", "label": "时间范围", "default": "last7d" },
    { "id": "f-region", "type": "dimension", "dimension": "region", "label": "区域", "display": "select" },
    { "id": "f-channel", "type": "dimension", "dimension": "channel", "label": "渠道", "display": "tabs" }
  ],
  "layout": { "type": "grid", "columns": 12 },
  "widgets": [
    {
      "id": "w-gmv",
      "type": "metricCard",
      "title": "GMV",
      "position": { "x": 0, "y": 0, "w": 3, "h": 2 },
      "query": {
        "metrics": ["gmv"],
        "filters": { "subscribe": ["f-time", "f-region", "f-channel"] }
      },
      "display": { "prefix": "¥", "thousandsSeparator": true }
    },
    {
      "id": "w-order-count",
      "type": "metricCard",
      "title": "订单数",
      "position": { "x": 3, "y": 0, "w": 3, "h": 2 },
      "query": {
        "metrics": ["order-count"],
        "filters": { "subscribe": ["f-time", "f-region", "f-channel"] }
      },
      "display": { "unit": "单", "thousandsSeparator": true }
    },
    {
      "id": "w-by-region",
      "type": "barChart",
      "title": "GMV 按区域(点击柱条页内下钻)",
      "position": { "x": 0, "y": 2, "w": 6, "h": 4 },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["region"],
        "filters": { "subscribe": ["f-time", "f-channel"] }
      },
      "interactions": [
        { "on": "click", "writeFilter": "f-region", "value": "$dimension.region" }
      ]
    },
    {
      "id": "w-by-channel",
      "type": "barChart",
      "title": "GMV 按渠道(点击柱条页内下钻)",
      "position": { "x": 6, "y": 2, "w": 6, "h": 4 },
      "query": {
        "metrics": ["gmv"],
        "dimensions": ["channel"],
        "filters": { "subscribe": ["f-time", "f-region"] }
      },
      "interactions": [
        { "on": "click", "writeFilter": "f-channel", "value": "$dimension.channel" }
      ]
    }
  ]
}

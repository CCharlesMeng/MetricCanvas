{
  "schemaVersion": "1.0",
  "id": "region-map",
  "meta": {
    "description": "切片8 演示:地图区域着色/散点叠加、文本带参链接、筛选器树选与搜索形态"
  },
  "dataSources": {
    "map-china": {
      "fields": {
        "region": {
          "type": "string",
          "role": "dimension",
          "label": "区域",
          "format": "text"
        },
        "gmv": {
          "type": "number",
          "role": "metric",
          "label": "成交总额",
          "format": "number-grouped"
        }
      },
      "source": {
        "type": "query",
        "query": {
          "metrics": [
            "gmv"
          ],
          "dimensions": [
            "region"
          ],
          "filters": {
            "subscribe": [
              "f-time",
              "f-city"
            ]
          }
        }
      }
    },
    "map-world": {
      "fields": {
        "region": {
          "type": "string",
          "role": "dimension",
          "label": "区域",
          "format": "text"
        },
        "gmv": {
          "type": "number",
          "role": "metric",
          "label": "成交总额",
          "format": "number-grouped"
        }
      },
      "source": {
        "type": "query",
        "query": {
          "metrics": [
            "gmv"
          ],
          "dimensions": [
            "region"
          ],
          "filters": {
            "subscribe": [
              "f-time",
              "f-city"
            ]
          }
        }
      }
    },
    "by-region": {
      "fields": {
        "region": {
          "type": "string",
          "role": "dimension",
          "label": "区域",
          "format": "text"
        },
        "gmv": {
          "type": "number",
          "role": "metric",
          "label": "成交总额",
          "format": "number-grouped"
        }
      },
      "source": {
        "type": "query",
        "query": {
          "metrics": [
            "gmv"
          ],
          "dimensions": [
            "region"
          ],
          "filters": {
            "subscribe": [
              "f-time",
              "f-region",
              "f-city"
            ]
          }
        }
      }
    },
    "gmv": {
      "fields": {
        "gmv": {
          "type": "number",
          "role": "metric",
          "label": "成交总额",
          "format": "number-grouped"
        }
      },
      "source": {
        "type": "query",
        "query": {
          "metrics": [
            "gmv"
          ],
          "filters": {
            "subscribe": [
              "f-time",
              "f-region",
              "f-city"
            ]
          }
        }
      }
    }
  },
  "filters": [
    {
      "id": "f-time",
      "type": "timeRange",
      "label": "时间范围",
      "default": "last30d"
    },
    {
      "id": "f-city",
      "type": "dimension",
      "dimension": "city",
      "label": "城市",
      "display": "tree"
    },
    {
      "id": "f-region",
      "type": "dimension",
      "dimension": "region",
      "label": "区域",
      "display": "search"
    }
  ],
  "sections": [
    {
      "id": "overview",
      "layout": {
        "type": "grid",
        "columns": 12
      },
      "components": [
        {
          "id": "page-header",
          "type": "reportHeader",
          "layout": {
            "span": 12
          },
          "props": {
            "title": "区域地图(长尾组件演示)",
            "subtitle": "切片8 演示:地图区域着色/散点叠加、文本带参链接、筛选器树选与搜索形态"
          }
        },
        {
          "id": "intro",
          "type": "text",
          "layout": {
            "span": 12
          },
          "props": {
            "heading": "区域分布总览",
            "body": "地图按区域展示 GMV,mock 的大区值经 nameMap 声明映射到底图区域着色(演示映射);点击地图区域回写区域筛选,城市树选与区域搜索筛选器写入同一筛选状态。",
            "links": [
              {
                "label": "打开演示看板",
                "page": "demo",
                "carryFilters": [
                  "f-time",
                  "f-region"
                ]
              },
              {
                "label": "查看销售明细",
                "page": "sales-detail",
                "carryFilters": [
                  "f-time"
                ]
              }
            ]
          }
        },
        {
          "id": "map-china",
          "type": "mapChart",
          "layout": {
            "span": 7
          },
          "data": {
            "main": "map-china"
          },
          "props": {
            "title": "GMV 区域分布(中国底图,点击区域下钻)",
            "nameField": "region",
            "valueField": "gmv",
            "map": "china",
            "scatter": "effect",
            "nameMap": {
              "华东": "上海市",
              "华北": "北京市",
              "华南": "广东省"
            },
            "actions": [
              {
                "on": "click",
                "writeFilter": "f-region",
                "field": "region"
              }
            ]
          }
        },
        {
          "id": "map-world",
          "type": "mapChart",
          "layout": {
            "span": 5
          },
          "data": {
            "main": "map-world"
          },
          "props": {
            "title": "GMV 区域分布(世界底图,演示映射)",
            "nameField": "region",
            "valueField": "gmv",
            "map": "world",
            "scatter": "point",
            "nameMap": {
              "华东": "China",
              "华北": "Mongolia",
              "华南": "Vietnam"
            }
          }
        },
        {
          "id": "by-region",
          "type": "barChart",
          "layout": {
            "span": 7
          },
          "data": {
            "main": "by-region"
          },
          "props": {
            "title": "GMV 按区域(随全部筛选器联动)",
            "categoryField": "region",
            "series": [
              {
                "field": "gmv"
              }
            ]
          }
        },
        {
          "id": "gmv",
          "type": "metricCard",
          "layout": {
            "span": 5
          },
          "data": {
            "main": "gmv"
          },
          "props": {
            "title": "GMV(随筛选联动)",
            "rows": [
              {
                "label": "GMV(随筛选联动)",
                "valueField": "gmv"
              }
            ]
          }
        }
      ]
    }
  ]
}
